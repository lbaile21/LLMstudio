{
  "trailingComma": "es5",
  "semi": true,
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 100,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "quoteProps": "as-needed",
  "embeddedLanguageFormatting": "auto",
  "singleAttributePerLine": false,
  "htmlWhitespaceSensitivity": "css",
  "plugins": ["prettier-plugin-tailwindcss"],
  "overrides": [
    {
      "files": ["*.json", "*.jsonc", "*.json5"],
      "options": {
        "trailingComma": "none"
      }
    },
    {
      "files": [
        "package.json",
        "package-lock.json",
        "tsconfig*.json",
        ".vscode/*.json",
        ".devcontainer/*.json"
      ],
      "options": {
        "trailingComma": "none",
        "printWidth": 120
      }
    },
    {
      "files": ["*.md", "*.mdx"],
      "options": {
        "printWidth": 80,
        "proseWrap": "always",
        "singleQuote": false
      }
    },
    {
      "files": ["CHANGELOG.md", "HISTORY.md", "RELEASES.md"],
      "options": {
        "proseWrap": "preserve",
        "printWidth": 120
      }
    },
    {
      "files": ["README.md", "CONTRIBUTING.md", "docs/**/*.md", "docs/**/*.mdx"],
      "options": {
        "printWidth": 80,
        "proseWrap": "always",
        "singleQuote": false,
        "tabWidth": 2
      }
    },
    {
      "files": ["*.yml", "*.yaml"],
      "options": {
        "singleQuote": false,
        "tabWidth": 2
      }
    },
    {
      "files": [".github/workflows/*.yml", ".github/workflows/*.yaml"],
      "options": {
        "singleQuote": false,
        "printWidth": 120
      }
    },
    {
      "files": ["docker-compose*.yml", "docker-compose*.yaml"],
      "options": {
        "singleQuote": false,
        "printWidth": 120
      }
    },
    {
      "files": ["*.css", "*.scss", "*.less"],
      "options": {
        "singleQuote": false
      }
    },
    {
      "files": ["*.html", "*.handlebars", "*.hbs"],
      "options": {
        "singleQuote": false,
        "printWidth": 120,
        "htmlWhitespaceSensitivity": "strict"
      }
    },
    {
      "files": [
        "*.test.ts",
        "*.test.tsx",
        "*.spec.ts",
        "*.spec.tsx",
        "*.stories.ts",
        "*.stories.tsx"
      ],
      "options": {
        "printWidth": 120
      }
    },
    {
      "files": ["*.config.ts", "*.config.js", "*.config.mjs", "*.config.cjs"],
      "options": {
        "printWidth": 120,
        "trailingComma": "all"
      }
    },
    {
      "files": ["*.d.ts"],
      "options": {
        "printWidth": 120,
        "semi": true
      }
    },
    {
      "files": ["*.graphql", "*.gql"],
      "options": {
        "singleQuote": false,
        "printWidth": 120
      }
    },
    {
      "files": ["*.toml"],
      "options": {
        "singleQuote": false,
        "printWidth": 100
      }
    },
    {
      "files": ["*.svg"],
      "options": {
        "parser": "html",
        "printWidth": 120
      }
    },
    {
      "files": ["*.env", ".env.*", "*.sh", "*.bash"],
      "options": {
        "singleQuote": false,
        "printWidth": 120
      }
    },
    {
      "files": ["Dockerfile", "Dockerfile.*", "*.dockerfile"],
      "options": {
        "printWidth": 120
      }
    },
    {
      "files": ["*.prisma"],
      "options": {
        "printWidth": 120,
        "tabWidth": 2
      }
    },
    {
      "files": ["*.sql"],
      "options": {
        "singleQuote": false,
        "printWidth": 120,
        "tabWidth": 2
      }
    },
    {
      "files": ["*.ipynb"],
      "options": {
        "printWidth": 120,
        "trailingComma": "none"
      }
    }
  ]
}
