{
  "trailingComma": "es5",
  "semi": true,
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 100,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "quoteProps": "as-needed",
  "embeddedLanguageFormatting": "auto",
  "singleAttributePerLine": false,
  "htmlWhitespaceSensitivity": "css",
  "plugins": ["prettier-plugin-tailwindcss"],
  "overrides": [
    {
      "files": ["*.json", "*.jsonc"],
      "options": {
        "trailingComma": "none"
      }
    },
    {
      "files": ["package.json", "package-lock.json", "tsconfig*.json"],
      "options": {
        "trailingComma": "none",
        "printWidth": 120
      }
    },
    {
      "files": ["*.md", "*.mdx"],
      "options": {
        "printWidth": 80,
        "proseWrap": "always",
        "singleQuote": false
      }
    },
    {
      "files": ["*.yml", "*.yaml"],
      "options": {
        "singleQuote": false,
        "tabWidth": 2
      }
    },
    {
      "files": ["*.css", "*.scss", "*.less"],
      "options": {
        "singleQuote": false
      }
    },
    {
      "files": ["*.html"],
      "options": {
        "singleQuote": false,
        "printWidth": 120,
        "htmlWhitespaceSensitivity": "strict"
      }
    },
    {
      "files": ["*.test.ts", "*.test.tsx", "*.spec.ts", "*.spec.tsx"],
      "options": {
        "printWidth": 120
      }
    },
    {
      "files": ["*.config.ts", "*.config.js", "*.config.mjs", "*.config.cjs"],
      "options": {
        "printWidth": 120,
        "trailingComma": "all"
      }
    },
    {
      "files": ["*.d.ts"],
      "options": {
        "printWidth": 120,
        "semi": true
      }
    },
    {
      "files": ["*.graphql", "*.gql"],
      "options": {
        "singleQuote": false,
        "printWidth": 120
      }
    },
    {
      "files": ["*.toml"],
      "options": {
        "singleQuote": false,
        "printWidth": 100
      }
    },
    {
      "files": [".vscode/*.json", ".devcontainer/*.json"],
      "options": {
        "trailingComma": "none",
        "printWidth": 120
      }
    },
    {
      "files": ["*.stories.ts", "*.stories.tsx"],
      "options": {
        "printWidth": 120
      }
    },
    {
      "files": ["*.svg"],
      "options": {
        "parser": "html",
        "printWidth": 120
      }
    },
    {
      "files": ["*.env", ".env.*"],
      "options": {
        "singleQuote": false
      }
    },
    {
      "files": ["*.sh", "*.bash"],
      "options": {
        "printWidth": 120,
        "singleQuote": false
      }
    },
    {
      "files": ["*.handlebars", "*.hbs"],
      "options": {
        "singleQuote": false,
        "printWidth": 120
      }
    },
    {
      "files": ["CHANGELOG.md", "HISTORY.md"],
      "options": {
        "proseWrap": "preserve",
        "printWidth": 120
      }
    }
  ]
}
