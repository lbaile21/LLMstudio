{
  "$schema": "https://mintlify.com/schema.json",
  "name": "LLMstudio Docs",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg",
    "alt": "LLMstudio documentation"
  },
  "favicon": "/favicon.jpg",
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373",
    "background": {
      "dark": "#0B1120",
      "light": "#FFFFFF"
    },
    "anchors": {
      "from": "#0D9373",
      "to": "#07C983"
    }
  },
  "metadata": {
    "og:title": "LLMstudio Documentation",
    "og:description": "Build, evaluate, and ship reliable LLM apps with LLMstudio.",
    "og:site_name": "LLMstudio Docs",
    "twitter:site": "@tensoropsai"
  },
  "topbarLinks": [
    {
      "name": "Support",
      "url": "mailto:claudio@tensorops.ai?subject=LLMstudio%20support"
    },
    {
      "name": "Changelog",
      "url": "https://github.com/tensoropsai/llmstudio/releases"
    }
  ],
  "topbarCtaButton": {
    "name": "TensorOps",
    "url": "https://tensorops.ai",
    "ariaLabel": "Visit the TensorOps website"
  },
  "tabs": [
    {
      "name": "API Reference",
      "url": "api-reference"
    },
    {
      "name": "Guides",
      "url": "guides"
    }
  ],
  "anchors": [
    {
      "name": "Community",
      "icon": "discord",
      "url": "https://discord.gg/GkAfPZR9wy",
      "ariaLabel": "Join the LLMstudio Discord community"
    },
    {
      "name": "GitHub",
      "icon": "github",
      "url": "https://github.com/tensoropsai/llmstudio",
      "ariaLabel": "View LLMstudio source code on GitHub"
    },
    {
      "name": "Blog",
      "icon": "newspaper",
      "url": "https://tensorops.ai/blog",
      "ariaLabel": "Read the TensorOps blog"
    }
  ],
  "navigation": [
    {
      "group": "Get Started",
      "pages": ["quickstart", "support"]
    },
    {
      "group": "Guides",
      "pages": [
        "guides/performance",
        "guides/caching",
        "guides/streaming",
        "guides/error-handling"
      ]
    },
    {
      "group": "Endpoint Examples",
      "pages": [
        {
          "group": "LLM",
          "icon": "sparkles",
          "pages": [
            "api-reference/llm/list-providers",
            "api-reference/llm/list-models",
            "api-reference/llm/chat"
          ]
        }
      ]
    }
  ],
  "footerSocials": {
    "github": "https://github.com/tensoropsai/llmstudio",
    "linkedin": "https://www.linkedin.com/company/tensoropsai",
    "x": "https://twitter.com/tensoropsai",
    "youtube": "https://www.youtube.com/@tensorops"
  },
  "api": {
    "baseUrl": "http://localhost:8001",
    "auth": {
      "method": "none"
    },
    "playground": {
      "mode": "show"
    },
    "request": {
      "example": {
        "languages": ["curl", "python", "javascript", "go", "typescript"]
      }
    }
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  },
  "seo": {
    "indexHiddenPages": false
  },
  "search": {
    "prompt": "Search the LLMstudio docs (providers, models, chat)..."
  },
  "redirects": [
    {
      "source": "/docs/quickstart",
      "destination": "/quickstart"
    },
    {
      "source": "/docs/:slug",
      "destination": "/:slug"
    },
    {
      "source": "/api",
      "destination": "/api-reference/llm/chat"
    }
  ]
}
